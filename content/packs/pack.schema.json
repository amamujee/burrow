{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amamujee/burrow/content/packs/pack.schema.json",
  "title": "Burrow Pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "summary", "audience", "sources", "cards"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 2
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "status": {
      "type": "string",
      "enum": ["draft", "needs-review", "playable"]
    },
    "audience": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minAge", "maxAge"],
      "properties": {
        "minAge": {
          "type": "integer",
          "minimum": 2
        },
        "maxAge": {
          "type": "integer",
          "minimum": 2
        },
        "readingLevel": {
          "type": "string"
        }
      }
    },
    "recommendedModes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["quiz", "versus", "trumps", "sort", "fact", "peek", "number", "odd"]
      },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 2
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "cards": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "image", "imageAlt", "imageCredit", "imageSourceUrl", "fact", "stats", "categories"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 2
          },
          "image": {
            "type": "string",
            "pattern": "^/burrow-assets/.+"
          },
          "imageAlt": {
            "type": "string",
            "minLength": 2
          },
          "imageCredit": {
            "type": "string",
            "minLength": 2
          },
          "imageSourceUrl": {
            "type": "string",
            "format": "uri"
          },
          "fact": {
            "type": "string",
            "minLength": 32
          },
          "stats": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "label", "value", "unit"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                },
                "label": {
                  "type": "string",
                  "minLength": 2
                },
                "value": {
                  "type": "number"
                },
                "unit": {
                  "type": "string"
                },
                "direction": {
                  "type": "string",
                  "enum": ["higher", "lower"]
                },
                "note": {
                  "type": "string"
                }
              }
            }
          },
          "categories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2
            },
            "uniqueItems": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            },
            "uniqueItems": true
          },
          "metadata": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "difficultyBand": {
                "type": "string",
                "enum": ["easy", "medium", "hard"]
              },
              "recognition": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "taxonomyGroup": {
                "type": "string",
                "minLength": 2
              },
              "accuracyNote": {
                "type": "string",
                "minLength": 8
              },
              "imageDistinctGroup": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              }
            }
          },
          "readingPrompts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 12
            }
          }
        }
      }
    }
  }
}
